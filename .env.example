# Docker Compose wczytuje ten plik automatycznie z katalogu, w którym leży docker-compose.yml.

# --- Ngrok w Dockerze (profil „tunnel”) ---
# Błąd ERR_NGROK_4018 = brak tokena, nieważny token albo konto ngrok niezweryfikowane.
# Token: https://dashboard.ngrok.com/get-started/your-authtoken
#
# Sposób A — zawsze z tunelem przy „docker compose up”:
#   Odkomentuj obie linie:
# COMPOSE_PROFILES=tunnel
# NGROK_AUTHTOKEN=twoj_token_tutaj
#
# Sposób B — tunel tylko gdy podasz profil w CLI (np. skrypt dev-docker-ngrok.ps1):
#   Zostaw COMPOSE_PROFILES puste; uruchamiaj: docker compose --profile tunnel up -d

# COMPOSE_PROFILES=tunnel
# NGROK_AUTHTOKEN=

# Opcjonalnie: port na hoście do panelu inspect ngrok (w kontenerze dalej 4040).
# NGROK_INSPECT_PORT=14040
