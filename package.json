{
  "name": "panstwa-miasta-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend-desktop",
    "frontend-mobile"
  ],
  "scripts": {
    "dev:desktop": "npm run dev --workspace=frontend-desktop",
    "dev:mobile": "npm run dev --workspace=frontend-mobile",
    "build:desktop": "npm run build --workspace=frontend-desktop",
    "build:mobile": "npm run build --workspace=frontend-mobile",
    "build:all": "npm run build:desktop && npm run build:mobile"
  }
}
