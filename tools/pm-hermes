#!/usr/bin/env bash
# pm-hermes — fill a template, then feed it to Hermes
# Usage: pm-hermes <feature|fix|review|config>
set -euo pipefail

TYPE="${1:-}"
OUTPUT_FILE="/tmp/pm-prompt-output.md"

usage() {
    echo "Usage: pm-hermes <feature|fix|review|config>"
    echo ""
    echo "Templates:"
    echo "  feature — Feature: plan + deploy + cleanup"
    echo "  fix     — Bug fix: diagnose + deploy + cleanup"
    echo "  review  — Code review / PR"
    echo "  config  — Config / infra change"
    exit 1
}

case "$TYPE" in
    feature|fix|review|config) ;;
    *) usage ;;
esac

if ! command -v pm-prompt &>/dev/null; then
    echo "[!] pm-prompt not found. Add alias to .bashrc:"
    echo "    alias pm-prompt=\"\$HOME/workspace/panstwa-miasta/tools/pm-prompt\""
    exit 1
fi

if ! command -v hermes &>/dev/null; then
    echo "[!] hermes not found in PATH"
    exit 1
fi

echo ""
echo "=== pm-hermes: $TYPE ==="
echo "Wypelnij formularz. Po zakonczeniu Hermes wystartuje z gotowym inputem."
echo ""

pm-prompt "$TYPE"

if [ ! -f "$OUTPUT_FILE" ]; then
    echo "[!] Output file not found: $OUTPUT_FILE"
    exit 1
fi

PROMPT_CONTENT=$(cat "$OUTPUT_FILE")

if [ -z "$PROMPT_CONTENT" ]; then
    echo "[!] Formularz pusty — anuluje."
    exit 1
fi

echo ""
echo "=== Uruchamianie Hermes z wypelnionym formularzem... ==="
echo ""

hermes -z "$PROMPT_CONTENT"
