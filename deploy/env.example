# Skopiuj fragment do Environment= w unit systemd albo do pliku EnvironmentFile=
#
# Za reverse proxy (Caddy / nginx) — limity IP i logi z prawdziwym klientem:
PM_TRUST_X_FORWARDED_FOR=1

# Opcjonalnie (domyślne sensowne — zostaw wyłączone, dopóki nie potrzebujesz):
# PM_MAX_ROOMS=512
# PM_WS_NEW_ROOMS_PER_IP_PER_MIN=24
# PM_WS_CONNECTS_PER_IP_PER_MIN=200
# PM_WS_MESSAGES_PER_CONN_PER_MIN=120
# PM_RATE_HTTP_API_CREATE_ROOM=24

# Turso / libSQL (embedded replica na VPS; oba puste = lokalny plik SQLite):
# LIBSQL_URL=libsql://twoja-baza.turso.io
# LIBSQL_AUTH_TOKEN=
# LIBSQL_SYNC_INTERVAL=60

# Umami Cloud (opcjonalnie — oba puste = brak skryptu analityki w HTML):
# UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
# UMAMI_WEBSITE_ID=
