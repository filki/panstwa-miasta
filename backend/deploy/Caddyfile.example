# Skopiuj jako /etc/caddy/Caddyfile (lub do sites-enabled wg dystrybucji).
# Przed użyciem: podmień domenę. DNS A/AAAA → IP serwera.

www.twoja-domena.pl {
	redir https://twoja-domena.pl{uri} permanent
}

twoja-domena.pl {
	encode gzip zstd

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		Content-Security-Policy "frame-ancestors 'none'"
	}

	# Ścieżka = katalog clone na VPS (domyślnie /srv/panstwa-miasta).
	@maintenance file /etc/caddy/maintenance.on
	handle @maintenance {
		root * /srv/panstwa-miasta/backend/deploy/maintenance
		rewrite * /index.html
		file_server
	}

	# Gdy uvicorn nie odpowiada — zamiast surowego 502 w przeglądarce.
	handle_errors {
		@down expression `{http.error.status_code} >= 502 && {http.error.status_code} <= 504`
		handle @down {
			root * /srv/panstwa-miasta/backend/deploy/maintenance
			rewrite * /index.html
			file_server
		}
	}

	reverse_proxy 127.0.0.1:8000
}
