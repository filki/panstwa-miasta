#!/bin/sh
# commit-msg hook — wymaga KB-Updated: yes w tresci commita
#
# Instaluj: git config core.hooksPath .githooks
# Pomin: SKIP_KB=1 git commit ...

MSG_FILE="$1"

if [ -n "$SKIP_KB" ]; then
    exit 0
fi

if ! grep -qi "KB-Updated:" "$MSG_FILE"; then
    echo ""
    echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
    echo " Brak 'KB-Updated: yes' w tresci commita!"
    echo " Dodaj na końcu wiadomości: KB-Updated: yes"
    echo " Lub pomiń: SKIP_KB=1 git commit ..."
    echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
    echo ""
    exit 1
fi
